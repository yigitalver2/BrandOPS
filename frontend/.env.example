# ——— Auth ———
# Oturum JWT imza anahtarı. Üretimde MUTLAKA güçlü, rastgele bir değer ayarla:
#   openssl rand -base64 32
AUTH_SECRET=

# ——— Veritabanı (libSQL) ———
# Lokal geliştirme: boş bırak → otomatik "file:local.db" kullanılır.
# Üretim (Vercel): Turso veritabanı bağlantısı.
#   DATABASE_URL=libsql://<db>-<org>.turso.io
#   DATABASE_AUTH_TOKEN=<turso-token>
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# ——— Backend (canlı pipeline) ———
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
