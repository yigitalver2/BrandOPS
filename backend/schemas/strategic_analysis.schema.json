{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "strategic_analysis.schema.json",
  "title": "Strategic Analysis",
  "description": "StrategyAgent çıktısı — stratejik dönemler + dönem detayları + sentezlenmiş anlatı.",
  "type": "object",
  "required": ["periods", "synthesis_narrative"],
  "additionalProperties": false,
  "properties": {
    "generated_at": { "type": "string" },
    "periods": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/period" }
    },
    "synthesis_narrative": { "type": "string", "minLength": 1 }
  },
  "definitions": {
    "period": {
      "type": "object",
      "required": [
        "name", "start_year", "end_year", "geographic_focus", "strategy",
        "initiatives", "transition_in", "transition_out", "financial_summary",
        "brand_product_evolution", "kpi_movement"
      ],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "start_year": { "type": "integer" },
        "end_year": { "type": "integer" },
        "geographic_focus": { "type": "array", "items": { "type": "string" } },
        "strategy": { "type": "string" },
        "initiatives": { "type": "array", "items": { "type": "string" } },
        "transition_in": { "type": "string" },
        "transition_out": { "type": "string" },
        "financial_summary": { "type": "string" },
        "brand_product_evolution": { "type": "string" },
        "kpi_movement": { "type": "string" }
      }
    }
  }
}
